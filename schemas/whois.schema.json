{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://declared-md.github.io/spec/schemas/whois.schema.json",
  "title": "whois.md",
  "description": "JSON Schema for whois.md v1.0 frontmatter. Validates the YAML frontmatter of an organization identity profile.",
  "type": "object",
  "required": ["declared", "kind", "name", "handle"],
  "additionalProperties": false,
  "if": {
    "required": ["links"]
  },
  "then": {
    "properties": {
      "links": {
        "anyOf": [
          { "type": "object", "required": ["site"] },
          { "type": "object", "required": ["github"] }
        ]
      }
    }
  },
  "properties": {
    "declared": {
      "type": "string",
      "enum": ["1.0"],
      "description": "Spec version. Must be the string '1.0'."
    },
    "kind": {
      "type": "string",
      "enum": ["whois"],
      "description": "Standard identifier. Must be 'whois'."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Legal or display name of the organization."
    },
    "handle": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,39}$",
      "description": "URL slug. Lowercase alphanumeric and hyphens, 2-39 characters."
    },
    "headline": {
      "type": "string",
      "maxLength": 120,
      "description": "Short one-line description of the organization."
    },
    "kind_of_org": {
      "type": "string",
      "enum": ["company", "nonprofit", "community", "collective", "gov", "educational"],
      "description": "Organization type."
    },
    "headquarters": {
      "type": "string",
      "description": "Free-form headquarters location string."
    },
    "founded": {
      "type": "string",
      "pattern": "^\\d{4}$",
      "description": "Year of founding as a four-digit string. Example: '2022'."
    },
    "size": {
      "type": "string",
      "enum": ["solo", "2-10", "11-50", "51-200", "201-500", "501-1000", "1000+"],
      "description": "Organization headcount range."
    },
    "industry": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Industry tags. Free-form strings."
    },
    "stack": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Publicly known technology stack."
    },
    "hiring": {
      "type": "boolean",
      "description": "Whether the organization is currently hiring."
    },
    "remote_policy": {
      "type": "string",
      "enum": ["remote-first", "hybrid", "office-first", "office-only"],
      "description": "Remote work policy."
    },
    "funding_stage": {
      "type": "string",
      "enum": ["bootstrapped", "pre-seed", "seed", "series-a", "series-b-plus", "public", "acquired"],
      "description": "Current funding stage."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Additional free-form tags for discoverability."
    },
    "links": {
      "type": "object",
      "description": "External organization links. At least site or github must be present. All URL values must use https://. The email key accepts mailto: URIs. Any key is allowed.",
      "properties": {
        "email": {
          "type": "string",
          "pattern": "^mailto:.+@.+\\..+",
          "description": "Contact email as a mailto URI."
        }
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^https://"
      }
    }
  }
}
